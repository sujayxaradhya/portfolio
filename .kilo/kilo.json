{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "{{DEFAULT_MINIMUM_TOKENS}}"
      }
    },
    "bettercms": {
      "command": "npx",
      "args": ["-y", "@betttercms/mcp"],
      "env": { "BETTERCMS_API_URL": "https://api.bettercms.ai" }
    }
  }
}
